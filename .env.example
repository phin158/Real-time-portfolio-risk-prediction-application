# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MARKET_DATA=market_data
KAFKA_GROUP_ID=portfolio_consumer_group
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CHANNEL=risk_updates

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Data ────────────────────────────────────────────────────────────────────
TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA
STREAM_INTERVAL_SECONDS=1.0
LOOKBACK_DAYS=7

# ── Model ───────────────────────────────────────────────────────────────────
MODEL_CHECKPOINT_PATH=model/checkpoints/tft_best.pt
DEVICE=cpu
